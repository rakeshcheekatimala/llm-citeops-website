{
  "name": "answerlint-website",
  "version": "0.1.0",
  "description": "AnswerLint — audit websites for AI-generated answers.",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "load:test:business": "k6 run load-tests/k6/business-scan.js",
    "load:test:playground": "k6 run load-tests/k6/playground-audit.js"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "next": "^15.5.14",
    "next-intl": "^4.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9",
    "eslint-config-next": "^15.5.14",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^1.6.1"
  }
}
